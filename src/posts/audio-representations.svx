				<!-- Two teacher targets -->
				<rect x="6" y="6" width="36" height="16" rx="3" stroke="#1a9e8f" stroke-width="1.2"/>
				<text x="24" y="16" text-anchor="middle" fill="#1a9e8f" font-size="6" font-family="Quicksand, system-ui, sans-serif">acoustic</text>
				<text x="24" y="20" text-anchor="middle" fill="#1a9e8f" font-size="4.5" font-family="Quicksand, system-ui, sans-serif" opacity="0.6">EnCodec RVQ codes</text>
