      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "The client always has N beats of committed chords cached — zero perceived latency as long as no-stall holds.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The client always has N beats of committed chords cached — zero perceived latency as long as no-stall holds.",
