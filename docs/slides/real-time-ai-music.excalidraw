      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Aria-Duet evaluates output through musicological analysis by the authors — no blind user study.\nReaLJam has a user study but no musicological evaluation. Which tells us more?",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Aria-Duet evaluates output through musicological analysis by the authors — no blind user study.\nReaLJam has a user study but no musicological evaluation. Which tells us more?",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
    },
