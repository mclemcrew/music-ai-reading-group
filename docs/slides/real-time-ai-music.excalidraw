      "versionNonce": 1541023455,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "\"Maximizing algorithmic efficiency\noften destroys user experience\"\n— Transcript framing",
      "textAlign": "left",
