    },
    {
      "id": "97967508c61340598",
      "type": "text",
      "x": 15100,
      "y": 225,
      "width": 420.0,
      "height": 56.7,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1208945940,
      "version": 1,
      "versionNonce": 1088278961,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "8781002f84674fc9a",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Reward = D(chord | past, future) − D(chord | past)\nRL pushes online model to produce chords that\nlook like they 'knew' the future.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Reward = D(chord | past, future) − D(chord | past)\nRL pushes online model to produce chords that\nlook like they 'knew' the future.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
    },
    {
      "id": "36a15835c46146aa8",
      "type": "text",
      "x": 15100,
      "y": 370,
      "width": 453.59999999999997,
      "height": 37.800000000000004,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1695689893,
      "version": 1,
      "versionNonce": 887676924,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "8781002f84674fc9a",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Connection: RL-S ≈ outcome reward model (RLHF sparse),\n             RL-M ≈ process reward model (RLHF dense)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Connection: RL-S ≈ outcome reward model (RLHF sparse),\n             RL-M ≈ process reward model (RLHF dense)",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
    },
