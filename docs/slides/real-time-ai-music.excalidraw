    {
      "id": "7641f32c14574edfb",
      "type": "text",
      "x": 19410,
      "y": 96,
      "width": 798.0,
      "height": 37.800000000000004,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
