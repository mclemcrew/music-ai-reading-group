      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "ReaLJam found the surprisal–control paradox: more control → lower satisfaction.\nShould future AI music tools intentionally reduce user control? What are the limits?",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ReaLJam found the surprisal–control paradox: more control → lower satisfaction.\nShould future AI music tools intentionally reduce user control? What are the limits?",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
