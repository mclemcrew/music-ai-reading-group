      "roundness": null,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "Notes still sounding at handover have unknown duration.\nModel predicts next 100–200ms to establish correct context\nbefore full generation begins.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Notes still sounding at handover have unknown duration.\nModel predicts next 100–200ms to establish correct context\nbefore full generation begins.",
