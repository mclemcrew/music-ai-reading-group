      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 18,
      "fontFamily": 3,
      "text": "L × (60/BPM) > RTT",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "L × (60/BPM) > RTT",
