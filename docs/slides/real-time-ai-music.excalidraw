    {
      "id": "8abec794375e4fbe8",
      "type": "text",
      "x": 1640,
      "y": 217,
      "width": 468.0,
      "height": 60.75000000000001,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 554585811,
      "version": 1,
      "versionNonce": 1974899043,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "93c7f06cf5b24724b",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "Music is not a thing but a social activity — a verb.\nAI tools that require text prompts are fundamentally\nasynchronous and disembodied. They break musicking.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Music is not a thing but a social activity — a verb.\nAI tools that require text prompts are fundamentally\nasynchronous and disembodied. They break musicking.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
    {
      "id": "dd20f3a617af4c80a",
      "type": "text",
      "x": 1640,
      "y": 320,
      "width": 183.6,
      "height": 24.3,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
