      "version": 1,
      "versionNonce": 1271086151,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "93c7f06cf5b24724b",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "KV cache cold-start at handover time takes 1–2 seconds.\nThis single bottleneck blocks all real-time AI music work.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "KV cache cold-start at handover time takes 1–2 seconds.\nThis single bottleneck blocks all real-time AI music work.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
