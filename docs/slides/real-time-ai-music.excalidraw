      "text": "The optimal state of absorbed, effortless engagement.\nRequires immediate feedback. Breaks at ~150ms disruption.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The optimal state of absorbed, effortless engagement.\nRequires immediate feedback. Breaks at ~150ms disruption.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
