      "text": "Examples from the paper:\n• Carmen Overture → vocabulary test\n• Liszt Ave Maria → counterpoint\n• Hungarian Rhapsody → prosody\n• The Entertainer → ragtime style",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Examples from the paper:\n• Carmen Overture → vocabulary test\n• Liszt Ave Maria → counterpoint\n• Hungarian Rhapsody → prosody\n• The Entertainer → ragtime style",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 10.66
    },
    {
      "id": "37776d404c2145d7b",
      "type": "text",
      "x": 9640,
      "y": 568,
      "width": 487.2,
      "height": 37.800000000000004,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
