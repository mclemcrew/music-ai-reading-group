    {
      "id": "44b6e94681fd4f35b",
      "type": "text",
      "x": 17640,
      "y": 375,
      "width": 173.4,
      "height": 22.950000000000003,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 895512148,
      "version": 1,
      "versionNonce": 464609274,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 17,
      "fontFamily": 1,
      "text": "Why this matters:",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why this matters:",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 13.94
    },
    {
      "id": "62421a76e8d14229b",
      "type": "text",
      "x": 17660,
      "y": 405,
      "width": 648.0,
      "height": 20.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1819083288,
      "version": 1,
      "versionNonce": 94846214,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "• We designed ReaLJam for control. The finding reverses the design goal.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• We designed ReaLJam for control. The finding reverses the design goal.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
    {
      "id": "53e56b7d298a4fb9a",
      "type": "text",
      "x": 17660,
      "y": 430,
      "width": 675.0,
      "height": 20.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1080585135,
      "version": 1,
      "versionNonce": 1628967281,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "• Musicians may want to be surprised — to be a responder, not a controller.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Musicians may want to be surprised — to be a responder, not a controller.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
    {
      "id": "e79970d85799460b8",
      "type": "text",
      "x": 17660,
      "y": 455,
      "width": 684.0,
      "height": 20.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1433620646,
      "version": 1,
      "versionNonce": 1618583210,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "• Analogous to jazz: playing 'inside' the changes is safe but uninteresting.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Analogous to jazz: playing 'inside' the changes is safe but uninteresting.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
    {
      "id": "f26003dffd6d4caa9",
      "type": "text",
      "x": 17660,
      "y": 480,
      "width": 738.0,
      "height": 20.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1168151556,
      "version": 1,
      "versionNonce": 1945636454,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 15,
      "fontFamily": 1,
      "text": "• This is not unique to AI music — it parallels findings in procedural generation.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• This is not unique to AI music — it parallels findings in procedural generation.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12.299999999999999
    },
    {
      "id": "243dde4e550d4203a",
      "type": "text",
      "x": 18480,
      "y": 120,
      "width": 226.2,
      "height": 87.75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 197315460,
      "version": 1,
      "versionNonce": 662876967,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "70516d4e0a0947f89",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "Discussion:\nDoes this finding generalize?\nDoes the paradox hold for\nall musicians, or only for\njazz/improv backgrounds?",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Discussion:\nDoes this finding generalize?\nDoes the paradox hold for\nall musicians, or only for\njazz/improv backgrounds?",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 10.66
    },
    {
      "id": "19d0ace1d9cf40b08",
      "type": "text",
      "x": 18480,
      "y": 310,
      "width": 265.2,
      "height": 52.650000000000006,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
