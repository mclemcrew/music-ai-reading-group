    {
      "id": "d0a7040166ec4f5b8",
      "type": "text",
      "x": 11900,
      "y": 1255,
      "width": 374.4,
      "height": 52.650000000000006,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 111592413,
      "version": 1,
      "versionNonce": 1308016181,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "cda6cc00b77c4241a",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "L = lookahead beats, RTT = round-trip time\nAt 150 BPM, 1-beat lookahead = 0.4s\nSingle-device RTT ≈ 0.08s  →  safe margin: 0.32s",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "L = lookahead beats, RTT = round-trip time\nAt 150 BPM, 1-beat lookahead = 0.4s\nSingle-device RTT ≈ 0.08s  →  safe margin: 0.32s",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 10.66
    },
    {
      "id": "e0d1ddc0d0664f69b",
      "type": "text",
      "x": 11240,
      "y": 1310,
      "width": 638.4,
      "height": 18.900000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 548868768,
      "version": 1,
      "versionNonce": 1423770852,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "cda6cc00b77c4241a",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Committed chords cannot change — they give the human time to react visually.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Committed chords cannot change — they give the human time to react visually.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
    },
    {
      "id": "13e1aa0cee2242ed9",
      "type": "text",
      "x": 11240,
      "y": 1335,
      "width": 722.4,
      "height": 18.900000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 1018691165,
      "version": 1,
      "versionNonce": 1710592293,
      "index": null,
      "isDeleted": false,
      "groupIds": [],
      "frameId": "cda6cc00b77c4241a",
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Uncommitted chords adapt as new melody arrives. Transition happens at commit deadline.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Uncommitted chords adapt as new melody arrives. Transition happens at commit deadline.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11.479999999999999
    },
    {
      "id": "9c64830a447247919",
      "type": "text",
      "x": 11243,
      "y": 1510,
      "width": 907.1999999999999,
      "height": 18.900000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
