      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "roundness": null,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "Note: evaluation is musicological analysis by the authors.\nNo user study in this paper — contrast with ReaLJam.",
